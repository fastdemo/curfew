{
  "manifest_version": 3,
  "name": "Curfew",
  "version": "1.0.0",
  "description": "blocks distracting websites and helps you stay locked in!",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "alarms",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Curfew"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/overlay.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["block.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/anko128.png",
    "48": "icons/anko128.png",
    "128": "icons/anko128.png"
  }
}
